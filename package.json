{
  "name": "cloudflare-unify-ddns",
  "version": "1.0.0",
  "description": "Self-hosted DDNS endpoint for UniFi OS that updates multiple Cloudflare DNS records simultaneously",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --format=esm",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
